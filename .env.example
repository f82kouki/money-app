# ===== warikan 環境変数 =====
# このファイルを .env にコピーして値を埋める:  cp .env.example .env

# --- データベース ---
# ローカルでお試し（DBサーバ不要・オフラインOK）:
DATABASE_URL=sqlite:///./warikan.db
#
# Supabase を使う場合（推奨・本番と同じDB）:
#   Supabase ダッシュボード → Project Settings → Database → Connection string
#   ・ローカル開発 / make db-init: "Direct connection"(port 5432)
#   ・Vercel(本番): "Connection pooling" の Transaction mode(port 6543)
#   コピーした postgresql://... をそのまま貼ればOK（コード側で psycopg 用に自動変換）
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres?sslmode=require

# --- 認証(JWT) ---
# 本番では必ずランダムな長い文字列に変更すること:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=dev-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# --- ログ ---
# INFO=通常 / DEBUG=詳細（全リクエスト）。エラー時はトレースバックを自動出力。
LOG_LEVEL=INFO

# --- CORS（ローカル開発のみ。Vite のオリジン）---
CORS_ORIGINS=http://localhost:5178

# --- Supabase Storage（お祝い画像。未設定ならローカルは base64 で動作）---
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_KEY=<service_role キー（サーバー専用・絶対にフロントに出さない）>
# SUPABASE_BUCKET=celebration
# SUPABASE_SIGNED_URL_TTL=86400
